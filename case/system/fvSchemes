FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;

    div(rhoPhi,U)           Gauss limitedLinearV 1;

    "div\(phi,alpha.*\)"        Gauss vanLeer;
    "div\(phir,alpha.*\)"       Gauss linear;

    "div\(phi,alpha.*\)"        Gauss vanLeer;
    "div\(Yiphir,alpha.*\)"     Gauss vanLeer;

    "div\(phi,.*\.argon.*\)"      Gauss vanLeer;
    "div\(phi,.*\.steel.*\)"   Gauss vanLeer;

    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;

    div(phi,T)              Gauss linearUpwind gradT;

}

laplacianSchemes
{
    default         Gauss linear orthogonal;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         orthogonal;
}

wallDist
{
    method meshWave;
}

fluxRequired
{
    default         no;
    p_rgh             ;
    Xvapour.argon;
    XCO2.argon;
    XO2.steel;
    "alpha.*";
}


